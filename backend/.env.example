# Copy this to .env and fill in your keys

# AcoustID — https://acoustid.org/login (free, open source)
ACOUSTID_API_KEY=your_acoustid_api_key_here

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ML paths (relative to backend/)
ONNX_MODEL_PATH=../ml/inference/music_encoder.onnx
FAISS_INDEX_PATH=../ml/inference/music_index.faiss
TRACK_METADATA_PATH=../ml/inference/track_metadata.json
